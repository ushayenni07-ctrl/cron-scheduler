// Sample data structure
let jobs = [];
let currentJobId = null;
 
// Initialize the application
document.addEventListener('DOMContentLoaded', function() {
    loadJobs();
    updateStats();
    startSimulation();
});
 
// Load jobs from localStorage or use sample data
function loadJobs() {
    const savedJobs = localStorage.getItem('cronJobs');
    if (savedJobs) {
        jobs = JSON.parse(savedJobs);
    } else {
        // Sample data
        jobs = [
            {
                id: '1',
                name: 'Database Backup',
                description: 'Backup production database',
                cronExpression: '0 2 * * *',
                status: 'running',
                nextRun: new Date(Date.now() + 2 * 60 * 60 * 1000).toISOString(),
                lastRun: new Date(Date.now() - 6 * 60 * 60 * 1000).toISOString(),
                maxRetries: 3,
                retryCount: 0,
                backoffSeconds: 5,
                jitterSeconds: 1,
                payload: { database: 'production', type: 'full' },
                createdAt: new Date().toISOString()
            },
            {
                id: '2',
                name: 'Email Reports',
                description: 'Send daily email reports',
                cronExpression: '0 9 * * *',
                status: 'paused',
                nextRun: new Date(Date.now() + 9 * 60 * 60 * 1000).toISOString(),
                lastRun: new Date(Date.now() - 15 * 60 * 60 * 1000).toISOString(),
                maxRetries: 2,
                retryCount: 0,
                backoffSeconds: 3,
                jitterSeconds: 0.5,
                payload: { recipients: ['admin@company.com'] },
                createdAt: new Date().toISOString()
            },
            {
                id: '3',
                name: 'API Health Check',
                description: 'Check external API health',
                cronExpression: '*/15 * * * *',
                status: 'failed',
                nextRun: new Date(Date.now() + 15 * 60 * 1000).toISOString(),
                lastRun: new Date(Date.now() - 5 * 60 * 1000).toISOString(),
                maxRetries: 5,
                retryCount: 2,
                backoffSeconds: 10,
                jitterSeconds: 2,
                payload: { endpoint: 'https://api.example.com/health' },
                createdAt: new Date().toISOString()
            }
        ];
        saveJobs();
    }
    renderJobs();
}
 
function saveJobs() {
    localStorage.setItem('cronJobs', JSON.stringify(jobs));
}
 
function renderJobs() {
    const tableBody = document.getElementById('jobs-table-body');
    tableBody.innerHTML = '';
 
    jobs.forEach(job => {
        const row = document.createElement('tr');
       
        const nextRun = new Date(job.nextRun);
        const lastRun = job.lastRun ? new Date(job.lastRun) : null;
       
        row.innerHTML = `
            <td>
                <strong>${job.name}</strong>
                ${job.description ? `<br><small>${job.description}</small>` : ''}
            </td>
            <td><code>${job.cronExpression}</code></td>
            <td><span class="status-badge status-${job.status}">${job.status}</span></td>
            <td>${formatDateTime(nextRun)}</td>
            <td>${lastRun ? formatDateTime(lastRun) : 'Never'}</td>
            <td>${job.retryCount}/${job.maxRetries}</td>
            <td>
                <div class="action-buttons">
                    <button class="action-btn btn-primary" onclick="showJobDetails('${job.id}')">
                        <i class="fas fa-eye"></i>
                    </button>
                    ${job.status === 'running' ?
                        `<button class="action-btn btn-warning" onclick="toggleJobStatus('${job.id}')">
                            <i class="fas fa-pause"></i>
                        </button>` :
                        `<button class="action-btn btn-success" onclick="toggleJobStatus('${job.id}')">
                            <i class="fas fa-play"></i>
                        </button>`
                    }
                    <button class="action-btn btn-danger" onclick="deleteJob('${job.id}')">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </td>
        `;
       
        tableBody.appendChild(row);
    });
}
 
function updateStats() {
    const runningCount = jobs.filter(job => job.status === 'running').length;
    const pausedCount = jobs.filter(job => job.status === 'paused').length;
    const failedCount = jobs.filter(job => job.status === 'failed').length;
   
    document.getElementById('running-count').textContent = runningCount;
    document.getElementById('paused-count').textContent = pausedCount;
    document.getElementById('failed-count').textContent = failedCount;
}
 
function formatDateTime(date) {
    return date.toLocaleString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    });
}
 
function showAddJobModal() {
    document.getElementById('add-job-modal').style.display = 'block';
}
 
function closeModal(modalId) {
    document.getElementById(modalId).style.display = 'none';
}
 
function addNewJob(event) {
    event.preventDefault();
   
    const formData = new FormData(event.target);
    const jobName = document.getElementById('job-name').value;
    const cronExpression = document.getElementById('cron-expression').value;
   
    const newJob = {
        id: Date.now().toString(),
        name: jobName,
        description: document.getElementById('job-description').value,
        cronExpression: cronExpression,
        status: 'running',
        nextRun: calculateNextRun(cronExpression),
        lastRun: null,
        maxRetries: parseInt(document.getElementById('max-retries').value),
        retryCount: 0,
        backoffSeconds: parseFloat(document.getElementById('backoff-seconds').value),
        jitterSeconds: parseFloat(document.getElementById('jitter-seconds').value),
        payload: parsePayload(document.getElementById('job-payload').value),
        createdAt: new Date().toISOString()
    };
   
    jobs.push(newJob);
    saveJobs();
    renderJobs();
    updateStats();
    closeModal('add-job-modal');
    event.target.reset();
   
    showToast('Job added successfully!', 'success');
}
 
function parsePayload(payloadText) {
    if (!payloadText.trim()) return {};
    try {
        return JSON.parse(payloadText);
    } catch (e) {
        showToast('Invalid JSON payload', 'error');
        return {};
    }
}
 
function calculateNextRun(cronExpression) {
    // Simple implementation - in real app, use cron parser
    const now = new Date();
    if (cronExpression === '*/5 * * * *') {
        now.setMinutes(now.getMinutes() + 5);
    } else if (cronExpression === '0 * * * *') {
        now.setHours(now.getHours() + 1);
        now.setMinutes(0);
    } else {
        now.setHours(now.getHours() + 2);
    }
    return now.toISOString();
}
 
function toggleJobStatus(jobId) {
    const job = jobs.find(j => j.id === jobId);
    if (job) {
        job.status = job.status === 'running' ? 'paused' : 'running';
        if (job.status === 'running') {
            job.nextRun = calculateNextRun(job.cronExpression);
        }
        saveJobs();
        renderJobs();
        updateStats();
        showToast(`Job ${job.status}`, 'success');
    }
}
 
function deleteJob(jobId) {
    if (confirm('Are you sure you want to delete this job?')) {
        jobs = jobs.filter(job => job.id !== jobId);
        saveJobs();
        renderJobs();
        updateStats();
        showToast('Job deleted successfully', 'success');
    }
}
 
function showJobDetails(jobId) {
    const job = jobs.find(j => j.id === jobId);
    if (job) {
        currentJobId = jobId;
        const content = document.getElementById('job-details-content');
        content.innerHTML = `
            <div class="job-details">
                <div class="detail-row">
                    <div class="detail-label">Name</div>
                    <div class="detail-value">${job.name}</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Description</div>
                    <div class="detail-value">${job.description || 'No description'}</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Cron Expression</div>
                    <div class="detail-value"><code>${job.cronExpression}</code></div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Status</div>
                    <div class="detail-value"><span class="status-badge status-${job.status}">${job.status}</span></div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Next Run</div>
                    <div class="detail-value">${formatDateTime(new Date(job.nextRun))}</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Last Run</div>
                    <div class="detail-value">${job.lastRun ? formatDateTime(new Date(job.lastRun)) : 'Never'}</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Retry Configuration</div>
                    <div class="detail-value">${job.retryCount}/${job.maxRetries} retries (backoff: ${job.backoffSeconds}s ± ${job.jitterSeconds}s)</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Payload</div>
                    <div class="detail-value"><pre>${JSON.stringify(job.payload, null, 2)}</pre></div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Created</div>
                    <div class="detail-value">${formatDateTime(new Date(job.createdAt))}</div>
                </div>
            </div>
        `;
        document.getElementById('job-details-modal').style.display = 'block';
    }
}
 
function filterJobs() {
    const searchTerm = document.getElementById('search-input').value.toLowerCase();
    const tableBody = document.getElementById('jobs-table-body');
    const rows = tableBody.getElementsByTagName('tr');
   
    for (let row of rows) {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
    }
}
 
function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.textContent = message;
   
    document.getElementById('toast-container').appendChild(toast);
   
    setTimeout(() => {
        toast.remove();
    }, 3000);
}
 
// Simulation functions for demo purposes
function startSimulation() {
    setInterval(() => {
        simulateJobRuns();
        updateMetrics();
    }, 5000);
}
 
function simulateJobRuns() {
    jobs.forEach(job => {
        if (job.status === 'running' && new Date(job.nextRun) <= new Date()) {
            // Simulate job execution
            const success = Math.random() > 0.2; // 80% success rate
           
            job.lastRun = new Date().toISOString();
           
            if (success) {
                job.retryCount = 0;
                job.nextRun = calculateNextRun(job.cronExpression);
            } else {
                job.retryCount++;
                if (job.retryCount >= job.maxRetries) {
                    job.status = 'failed';
                } else {
                    // Apply backoff with jitter
                    const backoff = job.backoffSeconds * Math.pow(2, job.retryCount - 1);
                    const jitter = (Math.random() * 2 - 1) * job.jitterSeconds;
                    const nextRun = new Date();
                    nextRun.setSeconds(nextRun.getSeconds() + backoff + jitter);
                    job.nextRun = nextRun.toISOString();
                }
            }
           
            saveJobs();
            renderJobs();
            updateStats();
        }
    });
}
 
function updateMetrics() {
    // Simulate metric updates
    const successRate = 80 + Math.floor(Math.random() * 15);
    const avgDuration = (1 + Math.random() * 3).toFixed(1);
    const totalExecutions = 1247 + Math.floor(Math.random() * 10);
   
    document.getElementById('success-rate').textContent = `${successRate}%`;
    document.getElementById('avg-duration').textContent = `${avgDuration}s`;
    document.getElementById('total-executions').textContent = totalExecutions.toLocaleString();
   
    // Update chart bars
    document.querySelectorAll('.chart-bar').forEach((bar, index) => {
        const widths = [successRate, avgDuration * 20, 80];
        bar.style.width = `${widths[index]}%`;
    });
}
 
// Close modals when clicking outside
window.onclick = function(event) {
    const modals = document.getElementsByClassName('modal');
    for (let modal of modals) {
        if (event.target === modal) {
            modal.style.display = 'none';
        }
    }
};
 
