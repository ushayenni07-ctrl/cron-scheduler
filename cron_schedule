<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cron Scheduler Dashboard</title>
    <link rel="stylesheet" href="styles.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <h1><i class="fas fa-clock"></i> Cron Scheduler</h1>
            <div class="stats">
                <span class="stat-item">
                    <i class="fas fa-play-circle"></i>
                    <span id="running-count">0</span> Running
                </span>
                <span class="stat-item">
                    <i class="fas fa-pause-circle"></i>
                    <span id="paused-count">0</span> Paused
                </span>
                <span class="stat-item">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span id="failed-count">0</span> Failed
                </span>
            </div>
        </header>
 
        <!-- Controls -->
        <div class="controls">
            <button class="btn btn-primary" onclick="showAddJobModal()">
                <i class="fas fa-plus"></i> Add Job
            </button>
            <div class="search-box">
                <input type="text" id="search-input" placeholder="Search jobs..." oninput="filterJobs()">
                <i class="fas fa-search"></i>
            </div>
        </div>
 
        <!-- Jobs Table -->
        <div class="jobs-table-container">
            <table class="jobs-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Schedule</th>
                        <th>Status</th>
                        <th>Next Run</th>
                        <th>Last Run</th>
                        <th>Retries</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="jobs-table-body">
                    <!-- Jobs will be populated here -->
                </tbody>
            </table>
        </div>
 
        <!-- Metrics Section -->
        <div class="metrics-section">
            <h2><i class="fas fa-chart-line"></i> Metrics</h2>
            <div class="metrics-grid">
                <div class="metric-card">
                    <h3>Job Success Rate</h3>
                    <div class="metric-value" id="success-rate">95%</div>
                    <div class="metric-chart">
                        <div class="chart-bar" style="width: 95%"></div>
                    </div>
                </div>
                <div class="metric-card">
                    <h3>Average Duration</h3>
                    <div class="metric-value" id="avg-duration">2.3s</div>
                    <div class="metric-chart">
                        <div class="chart-bar" style="width: 60%"></div>
                    </div>
                </div>
                <div class="metric-card">
                    <h3>Total Executions</h3>
                    <div class="metric-value" id="total-executions">1,247</div>
                    <div class="metric-chart">
                        <div class="chart-bar" style="width: 80%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
 
    <!-- Add Job Modal -->
    <div id="add-job-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Add New Job</h2>
                <span class="close" onclick="closeModal('add-job-modal')">&times;</span>
            </div>
            <form id="add-job-form" onsubmit="addNewJob(event)">
                <div class="form-group">
                    <label for="job-name">Job Name *</label>
                    <input type="text" id="job-name" required>
                </div>
                <div class="form-group">
                    <label for="job-description">Description</label>
                    <textarea id="job-description" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label for="cron-expression">Cron Expression *</label>
                    <input type="text" id="cron-expression" placeholder="*/5 * * * *" required>
                    <div class="cron-help">
                        <small>Examples: */5 * * * * (every 5 min), 0 */2 * * * (every 2 hours)</small>
                    </div>
                </div>
                <div class="form-group">
                    <label for="max-retries">Max Retries</label>
                    <input type="number" id="max-retries" min="0" max="10" value="3">
                </div>
                <div class="form-group">
                    <label for="backoff-seconds">Backoff Seconds</label>
                    <input type="number" id="backoff-seconds" min="1" max="300" value="5">
                </div>
                <div class="form-group">
                    <label for="jitter-seconds">Jitter Seconds</label>
                    <input type="number" id="jitter-seconds" min="0" max="10" value="1">
                </div>
                <div class="form-group">
                    <label for="job-payload">Payload (JSON)</label>
                    <textarea id="job-payload" rows="4" placeholder='{"key": "value"}'></textarea>
                </div>
                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('add-job-modal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Job</button>
                </div>
            </form>
        </div>
    </div>
 
    <!-- Job Details Modal -->
    <div id="job-details-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Job Details</h2>
                <span class="close" onclick="closeModal('job-details-modal')">&times;</span>
            </div>
            <div id="job-details-content">
                <!-- Details will be populated here -->
            </div>
        </div>
    </div>
 
    <!-- Toast Notifications -->
    <div id="toast-container"></div>
 
    <script src="script.js"></script>
</body>
</html>
 
